function updateNavArrows() {
  var el = document.getElementById('navArrows');
  if (!el) return;
  var inTour = currentScreen === 'tour';
  var canBack      = inTour ? tourIdx > 0 : historyIdx > 0;
  var canBackStart = true;
  var canFwd       = inTour ? tourIdx < TOUR_MODULES.length - 1 : historyIdx < navHistory.length - 1;
  var html = '';
  if (canBackStart) html += '<button class="nav-hist-btn" onclick="historyBackToStart()" title="Back to start">\u00ab</button>';
  if (canBack)      html += '<button class="nav-hist-btn" onclick="historyBack()" title="Go back">\u2039</button>';
  if (canFwd)       html += '<button class="nav-hist-btn" onclick="historyForward()" title="Go forward">\u203a</button>';
  el.innerHTML = html;
}
function pushHistory(screen) {
  navHistory = navHistory.slice(0, historyIdx + 1);
  if (navHistory[navHistory.length - 1] !== screen) {
    navHistory.push(screen);
    historyIdx = navHistory.length - 1;
  }
  updateNavArrows();
}
function historyBack() {
  if (currentScreen === 'tour') {
    if (tourIdx > 0) { tourIdx--; renderTourStop(); updateNavArrows(); }
    return;
  }
  if (historyIdx <= 0) { restoreOnboarding(); return; }
  historyIdx--;
  navigateTo(navHistory[historyIdx], true);
}
function historyBackToStart() {
  restoreOnboarding();
}
function historyForward() {
  if (currentScreen === 'tour') {
    if (tourIdx < TOUR_MODULES.length - 1) { tourIdx++; renderTourStop(); updateNavArrows(); }
    return;
  }
  if (historyIdx >= navHistory.length - 1) return;
  historyIdx++;
  navigateTo(navHistory[historyIdx], true);
}

function navigateTo(screen, skipHistory) {
  clearTimeouts();
  currentScreen = screen;
  if (!skipHistory) pushHistory(screen);
  else updateNavArrows();
  ({
    'welcome':       showWelcome,
    'goal-pick':     showGoalPick,
    'qa-deadline':   showQaDeadline,
    'goal-revealed': showGoalRevealed,
    'task-mock':     showTaskMock,
    'tour-complete':  showTourComplete,
    'home-settled':  showHomeSettled,
    'tour':          showTour
  })[screen]();
}

