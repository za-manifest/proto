var _orbCount = 0;
function orbAlive(on) {
  _orbCount = Math.max(0, _orbCount + (on ? 1 : -1));
  var alive = _orbCount > 0;
  var obOrb = document.querySelector('#ob-overlay .ob-chat-orb');
  /* orb-alive replaced by sage-mark-shimmer */
}
function push(html, delay) {
  orbAlive(true);
  var t = setTimeout(function() {
    var el = document.createElement('div');
    el.className = 'msg';
    el.innerHTML = html;
    cMsgs().appendChild(el);
    requestAnimationFrame(function() {
      requestAnimationFrame(function() {
        el.classList.add('visible');
        cMsgsScroll().scrollTop = cMsgsScroll().scrollHeight;
        orbAlive(false);
      });
    });
  }, delay || 0);
  msgTimeouts.push(t);
}

function pushChips(delay, opts, onSelect) {
  orbAlive(true);
  var t = setTimeout(function() {
    var wrap = document.createElement('div');
    wrap.className = 'msg visible qr-chips';
    opts.forEach(function(opt) {
      var btn = document.createElement('button');
      btn.className = 'qr-chip';
      btn.textContent = opt;
      btn.onclick = function() {
        if (wrap.parentNode) wrap.parentNode.removeChild(wrap);
        addUserReply(opt);
        onSelect(opt);
      };
      wrap.appendChild(btn);
    });
    cMsgs().appendChild(wrap);
    orbAlive(false);
    requestAnimationFrame(function() {
      requestAnimationFrame(function() {
        cMsgsScroll().scrollTop = cMsgsScroll().scrollHeight;
      });
    });
  }, delay || 0);
  msgTimeouts.push(t);
}

function pushTextInput(delay, placeholder, onSubmit) {
  orbAlive(true);
  var t = setTimeout(function() {
    var wrap = document.createElement('div');
    wrap.className = 'msg visible c-text-input';
    var input = document.createElement('input');
    input.type = 'text';
    input.placeholder = placeholder || 'Type your answer\u2026';
    var btn = document.createElement('button');
    btn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>';
    var submit = function() {
      var val = input.value.trim();
      if (!val) return;
      if (wrap.parentNode) wrap.parentNode.removeChild(wrap);
      addUserReply(val);
      onSubmit(val);
    };
    btn.onclick = submit;
    input.onkeydown = function(e) { if (e.key === 'Enter') submit(); };
    wrap.appendChild(input);
    wrap.appendChild(btn);
    cMsgs().appendChild(wrap);
    orbAlive(false);
    cMsgsScroll().scrollTop = cMsgsScroll().scrollHeight;
    setTimeout(function() { input.focus(); }, 50);
  }, delay || 0);
  msgTimeouts.push(t);
}

