function launchFTUE() {
  var overlay = document.getElementById('ob-overlay');
  overlay.style.transition = 'opacity 600ms ease';
  overlay.style.opacity = '0';
  setTimeout(function() {
    overlay.style.display = 'none';
    // Pass data from onboarding to FTUE
    var firstNameEl = document.getElementById('firstName');
    var derivedFirst = (firstNameEl ? firstNameEl.value.trim() : '') || ob_storedFirstName || '';
    if (derivedFirst) window._ob_firstName = derivedFirst;
    var bizNameEl = document.getElementById('bizName');
    if (bizNameEl) window._ob_bizName = bizNameEl.value.trim();
    // Patch PERSONA with live onboarding data (fallback to defaults)
    if (window._ob_bizName) PERSONA.businessName = window._ob_bizName;
    if (window._ob_firstName) PERSONA.name = window._ob_firstName;
    // FTUE goals, stage, and staff size are hardcoded — only biz name + first name pass through
    // Sync nav company name, user name, and avatar initial
    var navCompany = document.querySelector('.nav-company-name');
    if (navCompany) navCompany.textContent = PERSONA.businessName;
    var navUser = document.querySelector('.nav-company-user');
    if (navUser) navUser.textContent = PERSONA.name;
    var navAvatar = document.querySelector('.nav-company-avatar');
    if (navAvatar && PERSONA.name && !navAvatar.querySelector('img')) navAvatar.textContent = PERSONA.name.charAt(0).toUpperCase();
    // Show FTUE app
    var app = document.querySelector('.app');
    if (app) {
      app.style.opacity = '0';
      app.style.display = 'flex';
      requestAnimationFrame(function() {
        app.style.transition = 'opacity 500ms ease';
        app.style.opacity = '1';
        setTimeout(function() { app.style.transition = ''; }, 500);
      });
    }
    // Trigger FTUE welcome
    if (typeof navigateTo === 'function') navigateTo('welcome');
  }, 600);
}

/* ── RESTORE ONBOARDING (called when user backs out of FTUE) ── */
function restoreOnboarding() {
  var app = document.querySelector('.app');
  var overlay = document.getElementById('ob-overlay');
  if (!app || !overlay) return;
  app.style.transition = 'opacity 400ms ease';
  app.style.opacity = '0';
  setTimeout(function() {
    app.style.display = 'none';
    app.style.transition = '';
    overlay.style.opacity = '0';
    overlay.style.display = 'flex';
    overlay.style.transition = 'opacity 400ms ease';
    ob_transitionTo(13);
    requestAnimationFrame(function() {
      overlay.style.opacity = '1';
      setTimeout(function() { overlay.style.transition = ''; }, 400);
    });
  }, 400);
}

