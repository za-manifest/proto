    /* Step-specific hooks on arrival */
    if (step === 4) { setTimeout(function() { var f = document.getElementById('bizName'); if (f) f.focus(); }, 500); }
    if (step === 7) { populateStarterQuestions(); updateDashboardTitle(); }
    if (step === 10) { ob_initPricingStep(); }
    if (step === 14) { setTimeout(function() { launchFTUE(); }, 2800); }
    if (step === 13) { setTimeout(function() { ob_initStep13(); }, 250); }
    if (step === 11) {
