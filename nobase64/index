<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Manifest Product Vision '26</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&family=DM+Serif+Display&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,300;12..96,400;12..96,500;12..96,600;12..96,700;12..96,800&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --nav-w:280px;
  --companion-w:380px;
  --void:rgb(6,11,43);
  --void-96:rgba(6,11,43,.96);
  --void-80:rgba(6,11,43,.80);
  --void-64:rgba(6,11,43,.64);
  --void-48:rgba(6,11,43,.48);
  --void-32:rgba(6,11,43,.32);
  --void-16:rgba(6,11,43,.16);
  --void-08:rgba(6,11,43,.08);
  --void-04:rgba(6,11,43,.04);
  --freeze:rgb(156,156,227);
  --freeze-soft:rgba(156,156,227,.12);
  --freeze-mid:rgba(156,156,227,.24);
  --bg:rgb(246,246,253);
  --surface:#fff;
  --border:rgba(6,11,43,.08);
  --border-strong:rgba(6,11,43,.16);
  --text-1:rgb(6,11,43);
  --text-body:#2D2D2D;
  --text-2:rgba(6,11,43,.72);
  --text-3:rgba(6,11,43,.62);
  --text-4:rgba(6,11,43,.46);
  --green:rgb(134,197,100);
  --green-soft:rgba(134,197,100,.12);
  --radius-sm:8px;
  --radius:12px;
  --radius-lg:16px;
  --radius-xl:24px;
  --radius-pill:999px;
  --shadow:0 2px 8px rgba(6,11,43,.06),0 1px 2px rgba(6,11,43,.04);
  --shadow-lifted:0 8px 32px rgba(6,11,43,.08),0 2px 8px rgba(6,11,43,.04);
  --font:'Bricolage Grotesque',system-ui,sans-serif;
  --font-body:'DM Sans',-apple-system,BlinkMacSystemFont,sans-serif;
  --ease-out:cubic-bezier(0.33,0,0,1);
  --ease-spring:cubic-bezier(0.34,1.56,0.64,1);
  --freeze-text:rgb(65,65,155);
  --peach:rgba(253,217,194,1);
  --peach-soft:rgba(253,217,194,.15);
  --peach-mid:rgba(253,217,194,.45);
  --peach-text:rgba(107,58,31,.9);
  --card-shadow:0px 0px 0px 1px rgba(6,11,43,.04),0px 4px 12px rgba(6,11,43,.04);
}
html,body{height:100%;overflow:hidden;font-family:var(--font-body);color:var(--text-1);background:var(--bg)}
/* Hide scrollbars globally — keep scroll functionality */
*{scrollbar-width:none}
*::-webkit-scrollbar{display:none}

/* ── APP LAYOUT ─────────────────────────────── */
/* Matches real app: freeze-solid bg, nav floats as rounded card with p-8 margin */
.app{
  display:flex;height:100vh;overflow:hidden;
  background:var(--bg);
  padding:20px 28px 28px;
  gap:12px;
}

/* NAV — matches real app sidebar: bg-white, border-freeze-16, rounded-3xl, floats on bg */
.nav{
  width:var(--nav-w);flex-shrink:0;height:100%;
  background:var(--void);
  border:1px solid rgba(255,255,255,.07);
  border-radius:24px;
  display:flex;flex-direction:column;
  padding:12px;z-index:10;
  gap:2px;
  overflow:hidden;
}
.nav-company{
  display:flex;align-items:center;gap:12px;
  padding:12px 12px 14px;
  margin-bottom:4px;
  border-bottom:1px solid rgba(255,255,255,.08);
  cursor:pointer;
  border-radius:8px;
  transition:background 150ms ease,opacity 200ms ease;
  text-decoration:none;
}
.nav-company:hover{background:rgba(255,255,255,.06)}
.nav-company-avatar{
  width:32px;height:32px;border-radius:8px;
  background:linear-gradient(135deg,rgba(253,217,194,.95),rgba(253,190,150,.7));
  border:1px solid rgba(253,217,194,.4);
  display:flex;align-items:center;justify-content:center;
  flex-shrink:0;font-size:12px;font-weight:700;color:rgba(107,58,31,.9);
}
.nav-company-info{flex:1;min-width:0}
.nav-company-name{font-size:14px;font-weight:600;color:rgba(255,255,255,.88);letter-spacing:-.01em;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.nav-company-user{font-size:12px;color:rgba(255,255,255,.45);margin-top:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.nav-company-chevron{color:rgba(255,255,255,.5);flex-shrink:0}
.nav-company-chevron svg{width:14px;height:14px;display:block}
/* Nav items — real app: px-3 py-2.5 (12px/10px), rounded-lg (8px), text-void-64 inactive */
.nav-item{
  display:flex;align-items:center;gap:12px;
  padding:10px 12px;
  font-size:14px;font-weight:500;
  color:rgba(255,255,255,.42);
  cursor:pointer;
  transition:color 200ms ease,background 200ms ease,opacity 200ms ease;
  text-decoration:none;
  border-radius:8px;
}
.nav-item svg{width:20px;height:20px;flex-shrink:0;opacity:.5;transition:opacity 200ms ease}
.nav-item:hover{color:rgba(255,255,255,.82);background:rgba(255,255,255,.07)}
.nav-item:hover svg{opacity:.8}
.nav-item.active{color:rgba(253,217,194,1);background:rgba(253,217,194,.12);font-weight:500}
.nav-item.active svg{opacity:1;color:rgba(253,217,194,1)}
/* Lumari logo mark at bottom of nav — matches real app */
.nav-logo-mark{
  display:flex;align-items:center;justify-content:space-between;
  padding:8px 10px 4px;margin-top:4px;
}
.nav-logo-orb{
  width:36px;height:36px;border-radius:10px;
  display:flex;align-items:center;justify-content:center;
  flex-shrink:0;
}
.nav-logo-orb img{width:36px;height:36px;display:block}
.nav-spacer{flex:1}
.nav-divider{height:1px;background:rgba(255,255,255,.08);margin:4px 0}

/* MAIN PANE — transparent so the app gradient shows through edge-to-edge */
.main-pane{
  flex:0 0 0px;overflow:hidden;opacity:0;
  transition:flex-basis .55s var(--ease-out),opacity .45s ease .15s;
  background:transparent;
  display:flex;flex-direction:column;
}
.app.settled .main-pane{flex:1 1 auto;opacity:1;overflow-y:scroll;background:transparent;padding:0 44px}
/* HOME — gradient lives on the app container so it truly spans edge-to-edge */
.app.settled{
  background:
    radial-gradient(ellipse 95% 52% at 50% -6%, rgba(253,217,194,.16), transparent),
    var(--bg);
}

/* COMPANION — white rounded card, floats on right side matching nav card aesthetic */
.companion{
  flex:1 1 auto;min-width:0;height:100%;
  background:var(--surface);
  backdrop-filter:none;
  -webkit-backdrop-filter:none;
  border:1px solid rgba(156,156,227,.18);
  border-radius:24px;
  display:flex;flex-direction:column;overflow:hidden;
  transition:flex .12s var(--ease-out),max-width .12s var(--ease-out),opacity .1s ease;
}
.app.settled .companion{flex:0 0 var(--companion-w);max-width:var(--companion-w);background:var(--surface);backdrop-filter:none;-webkit-backdrop-filter:none;border-color:rgba(156,156,227,.18);box-shadow:-1px 0 0 rgba(6,11,43,.04),-8px 0 24px rgba(6,11,43,.04)}

/* FTUE — peach blush over the standard grey background */
.app:not(.settled){
  background:
    radial-gradient(ellipse 85% 55% at 60% -5%, rgba(253,217,194,.28), transparent),
    var(--bg);
}

/* FTUE focus — nav recedes during goal flow, active item pops */
.app:not(.settled) .nav-company{opacity:.5;pointer-events:none}
.app:not(.settled) .nav-item:not(.active){opacity:.42;pointer-events:none}
.app:not(.settled) .nav-logo-mark .nav-logo-orb{opacity:.45}
.nav-hist-arrows{display:flex;align-items:center;gap:4px}
.nav-hist-btn{background:none;border:none;color:rgba(255,255,255,.5);font-size:22px;font-weight:400;cursor:pointer;padding:4px 8px;line-height:1;border-radius:6px;font-family:var(--font-body);transition:color 120ms,background 120ms}
.nav-hist-btn:hover{color:rgba(255,255,255,.95);background:rgba(255,255,255,.1)}
/* Home — full contrast nav for real use */
.app.settled .nav-item:not(.active){color:rgba(255,255,255,.68)}
.app.settled .nav-item:not(.active) svg{opacity:.65}

/* FTUE — lock companion open, no collapse during goal/tour flows */
.app:not(.settled) .c-header-btn{display:none}
.app:not(.settled) .companion-toggle{display:none}
/* Tour — companion must stay open for the whole tour */
.app.tour-mode .c-header-btn{display:none}
.app.tour-mode .companion-toggle{display:none}
.app.settled .c-msgs{padding:28px 24px 20px;background:transparent}
.app.settled .c-actions{padding:8px 20px 16px}
.app.settled .c-input-bar{padding:12px 20px 20px}
.app.settled .c-header{padding:14px 16px 14px 20px}
.app.companion-hidden .companion{flex:0 0 0px;max-width:0;border:none;overflow:hidden;opacity:0}

/* Companion inner */
.c-header{
  padding:18px 24px 18px 32px;
  display:flex;align-items:center;gap:10px;flex-shrink:0;
}
.c-orb{
  width:26px;height:26px;border-radius:50%;
  background:radial-gradient(circle at 32% 28%,rgba(195,195,255,1),rgba(85,60,210,1) 50%,rgba(28,12,130,1));
  box-shadow:0 0 10px rgba(70,50,200,.55),0 0 0 1px rgba(120,100,240,.3);
  flex-shrink:0;
  display:flex;align-items:center;justify-content:center;
}
/* Orb "alive" pulse — breathe down and return, never exceeds 100% */
@keyframes orbBreath{
  0%,100%{transform:scale(1)}
  50%{transform:scale(.93)}
}
.orb-alive{animation:orbBreath 1.8s ease-in-out infinite}
#cProgressBar{height:3px;background:var(--border);flex-shrink:0;overflow:hidden}
#cProgressFill{height:100%;background:linear-gradient(90deg,#F5B896,#5a5ac8);width:0%;transition:width 550ms cubic-bezier(.4,0,.2,1);border-radius:0 1px 1px 0}
.c-header-btn{
  width:28px;height:28px;border-radius:8px;border:none;background:transparent;
  display:flex;align-items:center;justify-content:center;cursor:pointer;
  color:var(--text-4);transition:background 150ms ease,color 150ms ease;flex-shrink:0;
}
.c-header-btn:hover{background:var(--void-08);color:var(--text-2)}
.c-header-btn svg{width:15px;height:15px}
.c-header-identity{flex:1;display:flex;align-items:center;gap:11px;min-width:0}
.c-header-name{font-size:14px;font-weight:700;color:var(--text-1);letter-spacing:-.01em;flex-shrink:0}
.c-header-sep{font-size:13px;color:var(--text-3);flex-shrink:0}
.c-header-title{font-size:13px;font-weight:500;color:var(--text-2);letter-spacing:-.005em}
.c-msgs{
  flex:1;overflow-y:auto;
  padding:56px 80px 72px;
  display:flex;flex-direction:column;scroll-behavior:smooth;
  background:transparent;
}
.c-msgs-inner{
  max-width:620px;
  display:flex;flex-direction:column;gap:4px;
  width:100%;
  margin:0 auto;
}
.c-msgs::-webkit-scrollbar{width:4px}
.c-msgs::-webkit-scrollbar-thumb{background:var(--border-strong);border-radius:4px}
.main-pane::-webkit-scrollbar{width:4px}
.main-pane::-webkit-scrollbar-thumb{background:var(--border-strong);border-radius:4px}
.main-pane::-webkit-scrollbar-track{background:transparent}

/* Messages */
.msg{opacity:0;transform:translateY(6px);transition:opacity .3s ease,transform .3s var(--ease-out);max-width:100%}
.msg.visible{opacity:1;transform:none}
.msg.user-msg + .msg{margin-top:14px}
/* Bot messages: plain text, no bubble — Medium-scale typography */
.msg-bubble{display:block;font-size:15.5px;line-height:1.68;color:var(--text-body);font-weight:400;letter-spacing:-.01em}
.msg-bubble.bot{background:none;border:none;padding:0}
.msg-bubble.user{
  display:inline-block;
  background:var(--void-08);color:var(--text-1);
  border-radius:var(--radius-pill);
  padding:8px 16px;float:right;clear:both;
  font-size:14px;font-weight:500;
}
.msg.user-msg{text-align:right}
.msg.user-msg::after{content:'';display:table;clear:both}
/* Reaction row — removed from prototype */
.msg-reactions{display:none!important}
.msg-react-btn{
  width:24px;height:24px;border-radius:6px;border:none;background:transparent;
  display:flex;align-items:center;justify-content:center;cursor:pointer;
  color:var(--text-4);transition:background 150ms ease,color 150ms ease;
}
.msg-react-btn:hover{background:var(--void-08);color:var(--text-2)}
.msg-react-btn svg{width:13px;height:13px}

/* Typing indicator */
.typing-dots{
  display:inline-flex;align-items:center;gap:4px;padding:2px 0;
}
.typing-dot{
  width:6px;height:6px;border-radius:50%;background:var(--freeze);
  animation:typingBounce 1.2s ease infinite;
}
.typing-dot:nth-child(2){animation-delay:.2s}
.typing-dot:nth-child(3){animation-delay:.4s}
@keyframes typingBounce{
  0%,60%,100%{transform:translateY(0);opacity:.5}
  30%{transform:translateY(-5px);opacity:1}
}

/* Quick reply chips */
.qr-chips{display:flex;flex-wrap:wrap;gap:9px;padding-top:12px}
.qr-chip{
  background:var(--surface);border:1px solid var(--border-strong);
  border-radius:var(--radius-pill);padding:10px 18px;
  font-size:14px;font-weight:500;color:var(--text-1);
  font-family:var(--font-body);cursor:pointer;transition:all 160ms ease;
}
.qr-chip:hover{background:var(--freeze-soft);border-color:var(--freeze)}

/* Text input in companion */
.c-text-input{display:flex;gap:8px;align-items:center;padding-top:4px}
.c-text-input input{
  flex:1;height:40px;padding:0 14px;
  border:1px solid var(--border-strong);border-radius:var(--radius);
  font-size:13.5px;font-family:var(--font-body);color:var(--text-1);background:var(--surface);
  outline:none;transition:border-color 150ms ease,box-shadow 150ms ease;
}
.c-text-input input:focus{border-color:var(--freeze);box-shadow:0 0 0 3px var(--freeze-soft)}
.c-text-input button{
  height:40px;width:40px;border-radius:var(--radius);
  background:var(--void);border:none;cursor:pointer;
  display:flex;align-items:center;justify-content:center;flex-shrink:0;
  transition:opacity 160ms ease;
}
.c-text-input button:hover{opacity:.85}
.c-text-input button svg{width:16px;height:16px;color:#fff}

/* Persistent input bar */
.c-input-bar{
  padding:16px 32px 24px;
  flex-shrink:0;border-top:1px solid var(--border);
  display:flex;flex-direction:column;gap:10px;
}
.c-input-wrap{
  display:flex;align-items:center;gap:8px;
  background:var(--bg);
  border:1.5px solid var(--border-strong);
  border-radius:var(--radius-pill);
  padding:8px 8px 8px 16px;
  transition:border-color 150ms ease,box-shadow 150ms ease;
}
.c-input-wrap:focus-within{
  border-color:rgba(156,156,227,.6);
  box-shadow:0 0 0 3px var(--freeze-soft);
}
.c-input-wrap input{
  flex:1;border:none;background:transparent;outline:none;
  font-size:13.5px;font-family:var(--font-body);color:var(--text-1);
}
.c-input-wrap input::placeholder{color:var(--text-4)}
.c-input-send{
  width:30px;height:30px;border-radius:var(--radius-pill);
  background:var(--void);border:none;cursor:pointer;
  display:flex;align-items:center;justify-content:center;flex-shrink:0;
  transition:opacity 160ms ease;
}
.c-input-send:hover{opacity:.8}
.c-input-send svg{width:13px;height:13px;color:#fff}
/* Companion actions (CTA buttons above input bar) */
.c-actions{
  padding:12px 20px 16px;display:flex;flex-direction:column;gap:8px;
  flex-shrink:0;
}
.btn{
  width:100%;height:44px;border-radius:var(--radius);
  font-size:14px;font-weight:600;font-family:var(--font-body);cursor:pointer;
  transition:background 160ms ease;display:flex;align-items:center;justify-content:center;gap:8px;
}
.btn-primary{background:var(--void);color:#fff;border:1px solid transparent}
.tour-btn{margin-top:14px;width:100%}
@keyframes tour-pulse{0%,100%{background:var(--bg)}50%{background:rgb(238,238,252)}}
@keyframes liveDot{0%{box-shadow:0 0 0 0 rgba(232,88,88,.4)}70%{box-shadow:0 0 0 6px rgba(232,88,88,0)}100%{box-shadow:0 0 0 0 rgba(232,88,88,0)}}
.app.tour-pulsing{animation:tour-pulse 1.4s ease-in-out infinite}
.btn-primary:hover{background:#181d45}
.btn-secondary{background:transparent;border:1px solid var(--border-strong);color:var(--text-body);transition:all 180ms ease}
.btn-secondary:hover{background:var(--peach-soft);border-color:var(--peach);color:var(--text-1)}
.btn svg{width:16px;height:16px}

/* Welcome path cards */
.msg:has(.path-cards){margin-top:40px}
.path-cards{display:flex;flex-direction:column;align-items:center}
.path-btn-group{display:flex;flex-direction:column;gap:12px;width:max-content}
.path-card{
  background:var(--void);
  border:1px solid transparent;
  border-radius:var(--radius);
  padding:13px 22px;
  min-height:48px;
  cursor:pointer;
  transition:background 150ms ease,transform 150ms ease,box-shadow 150ms ease;
  font-family:var(--font-body);
  display:flex;align-items:center;justify-content:space-between;gap:32px;
}
.path-card:hover{background:#181d45}
.path-card:active{transform:translateY(0);box-shadow:none}
.path-card-title{
  font-size:14px;font-weight:600;color:#fff;
  letter-spacing:-.01em;flex:1;text-align:left;
}
.path-card-desc{display:none}
.path-card-arrow svg{width:13px;height:13px;color:rgba(255,255,255,.6);flex-shrink:0}

/* Goal tiles */
.goal-tiles{display:flex;flex-wrap:wrap;gap:8px;margin-top:14px;padding-top:2px}
.goal-tile{
  background:var(--surface);border:1.5px solid var(--border-strong);
  border-radius:var(--radius-pill);padding:9px 18px;cursor:pointer;
  transition:all 180ms ease;display:inline-flex;align-items:center;gap:10px;
  font-family:var(--font-body);text-align:left;
}
.goal-tile:hover{border-color:var(--peach);background:var(--peach-soft)}
.goal-tile-icon{
  width:22px;height:22px;border-radius:6px;background:var(--peach-soft);
  display:flex;align-items:center;justify-content:center;flex-shrink:0;
}
.goal-tile-icon svg{width:13px;height:13px;color:var(--peach-text)}
.goal-tile-name{font-size:13.5px;font-weight:600;color:var(--text-1)}

/* COMPANION TOGGLE */
.companion-toggle{
  position:fixed;top:26px;right:28px;z-index:200;
  width:44px;height:44px;border-radius:50%;
  background:rgba(143,44,126,.06);
  box-shadow:none;
  border:none;cursor:pointer;
  display:none;align-items:center;justify-content:center;
  transition:transform 350ms cubic-bezier(0.34,1.2,0.64,1),background 200ms ease;
}
.companion-toggle:hover{transform:scale(1.12);background:rgba(143,44,126,.08)}
.companion-toggle svg{width:15px;height:15px;color:#fff}

/* ── MAIN PANE ───────────────────────────────────────────────── */
.main-content{padding:12px 32px 32px;width:100%;min-height:100%}
.home-cols{display:grid;grid-template-columns:1fr 310px;gap:24px;align-items:start}
.home-col-main{}
.home-col-side{}
/* On narrower viewports, stack */
@media(max-width:900px){.home-cols{grid-template-columns:1fr}}
/* When companion sidebar is open, main content takes full width — companion is the sidebar */
.app.settled:not(.companion-hidden) .home-cols{grid-template-columns:1fr}
.app.settled:not(.companion-hidden) .home-col-side{display:none}
.app.settled:not(.companion-hidden) .goal-tile{padding:9px 12px;gap:7px}
.app.settled:not(.companion-hidden) .main-content{padding:12px 32px 32px}

.home-q-chip{padding:12px 14px;border:1px solid var(--border);border-left:2px solid var(--freeze);border-radius:var(--radius-sm);background:var(--surface);font-size:14px;font-weight:400;color:var(--text-body);cursor:pointer;line-height:1.5;transition:background 120ms,border-color 120ms;text-align:left;font-family:var(--font-body);width:100%}
.home-q-chip:hover{background:var(--freeze-soft);border-color:rgba(156,156,227,.4);color:var(--text-body)}
.other-goals-heading{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--text-2);margin-bottom:8px}
.home-mini-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-lg);padding:20px;display:flex;flex-direction:column;flex:1;min-width:0;box-shadow:var(--card-shadow)}
.home-mini-card-eyebrow{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--text-2);padding-bottom:10px;margin-bottom:10px;border-bottom:1px solid var(--border)}
.home-mini-card-title{font-size:20px;font-weight:800;color:var(--text-1);letter-spacing:-.025em;margin-bottom:6px;line-height:1.1;font-family:var(--font)}
.home-mini-card-sub{font-size:14px;color:var(--text-2);font-weight:400;margin-bottom:14px;line-height:1.55}
.home-mini-card-null{font-size:15px;font-weight:700;color:var(--void);margin-bottom:6px}
.kpi-ghost-wrap{border:1px solid var(--border);border-radius:var(--radius-lg);overflow:hidden;background:var(--surface);margin-bottom:16px;cursor:pointer;transition:border-color 150ms,box-shadow 150ms;box-shadow:var(--card-shadow)}
.kpi-ghost-wrap:hover{border-color:var(--border-strong);box-shadow:var(--shadow)}
.home-mini-cta{display:block;width:100%;padding:11px 14px;border:none;border-radius:var(--radius-sm);font-size:13px;font-weight:700;cursor:pointer;font-family:var(--font-body);text-align:center;margin-top:auto}
.home-mini-cta-primary{background:var(--void);color:#fff}
.home-mini-cta-secondary{background:var(--void-08);color:var(--text-1);border:1px solid var(--border)}
.home-mini-row{display:flex;gap:14px;margin-bottom:16px}
.home-kpi-null{background:var(--surface);border:1px dashed var(--border-strong);border-radius:var(--radius-lg);padding:14px 18px;display:flex;align-items:center;gap:16px;margin-bottom:16px}

/* Goal card */
.goal-card{
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:var(--radius-xl);
  padding:20px 22px;
  box-shadow:var(--card-shadow);
  animation:fadeInUp .5s var(--ease-out) both;
}
@keyframes fadeInUp{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:none}}
/* Progressive home screen reveal — first load only */
.home-reveal-1{animation:fadeInUp .9s var(--ease-out) .1s both}
.home-reveal-2{animation:fadeInUp .9s var(--ease-out) .36s both}
.home-reveal-3{animation:fadeInUp .9s var(--ease-out) .62s both}
.home-reveal-4{animation:fadeInUp .9s var(--ease-out) .88s both}
.home-reveal-5{animation:fadeInUp .9s var(--ease-out) 1.14s both}
.home-revealed .home-reveal-1,.home-revealed .home-reveal-2,.home-revealed .home-reveal-3,.home-revealed .home-reveal-4,.home-revealed .home-reveal-5{animation:none;opacity:1;transform:none}
/* Tour page cascade reveal */
.goal-badge{
  font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;
  color:var(--peach-text);background:var(--peach-mid);border:1px solid var(--peach);
  border-radius:var(--radius-pill);padding:3px 10px;display:inline-block;margin-bottom:10px;
}
.goal-card-title{font-size:22px;font-weight:800;color:var(--text-1);letter-spacing:-.03em;line-height:1.2;margin-bottom:6px;font-family:var(--font)}
.goal-card-context{font-size:14px;color:var(--text-2);line-height:1.6;margin-bottom:10px;font-weight:400;letter-spacing:-.005em}
.goal-progress-row{display:flex;align-items:center;gap:12px;margin-bottom:20px}
.goal-prog-bar{flex:1;height:5px;border-radius:3px;background:var(--void-08);overflow:hidden}
.goal-prog-fill{height:100%;border-radius:3px;background:var(--void);transition:width .8s var(--ease-out)}
.goal-prog-label{font-size:12px;font-weight:600;color:var(--text-2);white-space:nowrap}
.tasks-label{font-size:11px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--text-2);margin-bottom:10px}
.task-row{
  display:flex;align-items:center;gap:12px;
  padding:11px 14px;border-radius:var(--radius-lg);
  border:1px solid var(--border);background:var(--surface);margin-bottom:7px;box-shadow:var(--card-shadow);
  transition:background 200ms ease;
}
.task-row:last-child{margin-bottom:0}
.task-row.done{background:var(--void-04)}
.task-check{
  width:20px;height:20px;border-radius:6px;border:2px solid var(--border-strong);
  display:flex;align-items:center;justify-content:center;flex-shrink:0;
}
.task-row.done .task-check{background:var(--void);border-color:var(--void)}
.task-row.done .task-check svg{display:block}
.task-check svg{width:11px;height:11px;color:#fff;display:none}
.task-name{flex:1;font-size:13.5px;font-weight:500;color:var(--text-body)}
.task-row.done .task-name{color:var(--text-2);text-decoration:line-through}
.task-time{
  font-size:11px;font-weight:600;color:var(--freeze-text);
  background:var(--freeze-soft);border-radius:var(--radius-pill);padding:2px 9px;white-space:nowrap;
}
.task-row.done .task-time{color:var(--text-2);background:var(--void-04)}
.goal-card .task-time{font-weight:500;color:var(--text-3);background:none;padding:0}
.goal-card .task-row.done .task-time{display:none}
.goal-card .task-row{border-left:2.5px solid var(--freeze)}
.goal-card .task-row.done{border-left-color:var(--void-16)}
.goal-card .task-row-watch{border-left-color:#d4a843}
.goal-card .task-row-book{border-left-color:#d4956c}
.goal-card .task-row-check{border-left-color:#5a9f3b}
.task-type-icon{
  width:20px;height:20px;border-radius:6px;
  display:flex;align-items:center;justify-content:center;flex-shrink:0;
}
.task-type-icon svg{width:11px;height:11px}
.task-type-icon.watch{background:rgba(212,168,67,.12);color:#8a6d1e}
.task-type-icon.book{background:rgba(228,160,120,.15);color:#9b6840}
.task-type-icon.check{background:rgba(134,197,100,.15);color:#3a7a2e}
.next-task-cta-wrap{margin-top:16px;display:flex;align-items:center;justify-content:space-between;gap:12px}
.next-task-cta-label{font-size:12px;color:var(--text-2);font-weight:500}
.next-task-cta{
  display:inline-flex;align-items:center;background:var(--void);border-radius:var(--radius-pill);
  padding:10px 20px;cursor:pointer;transition:opacity 160ms ease;
  text-decoration:none;font-size:13.5px;font-weight:600;color:#fff;white-space:nowrap;flex-shrink:0;
}
.next-task-cta:hover{opacity:.88}
.other-goals{margin-top:22px;padding-top:20px;border-top:1px solid var(--border)}
/* .other-goals-note removed — replaced by .other-goals-heading in CSS above */
.other-goal-stub{
  display:flex;align-items:center;padding:12px 16px;flex:1;
  border:1px solid var(--border-strong);border-radius:var(--radius);gap:12px;
}
.other-goal-name{flex:1;font-size:14px;font-weight:600;color:var(--text-body)}
.other-goal-status{font-size:12px;color:var(--text-2);margin-top:1px}
.other-goal-cta{font-size:12px;font-weight:500;color:var(--freeze-text);text-decoration:none;white-space:nowrap;transition:opacity 150ms ease}
.other-goal-cta:hover{opacity:.7}

/* Win banner */
.win-banner{
  background:linear-gradient(135deg,rgba(134,197,100,.12),rgba(134,197,100,.06));
  border:1px solid rgba(134,197,100,.3);border-radius:var(--radius-lg);
  padding:14px 18px;display:inline-flex;align-items:center;gap:12px;margin-bottom:20px;
  animation:winBannerIn .45s var(--ease-out) both, winBannerGlow 1.2s ease-out .45s both;
  cursor:pointer;
}
@keyframes winBannerIn{
  from{opacity:0;transform:translateY(-10px) scale(.98)}
  to{opacity:1;transform:translateY(0) scale(1)}
}
@keyframes winBannerGlow{
  0%{box-shadow:0 0 0 0 rgba(134,197,100,.0),0 0 0 4px rgba(134,197,100,.28)}
  60%{box-shadow:0 0 0 0 rgba(134,197,100,.0),0 0 0 8px rgba(134,197,100,.14)}
  100%{box-shadow:none}
}
.win-icon{
  width:36px;height:36px;border-radius:10px;background:rgba(134,197,100,.2);
  display:flex;align-items:center;justify-content:center;flex-shrink:0;
}
.win-icon svg{width:18px;height:18px;color:#5a9f3b}
.win-text{flex:1;font-size:13.5px;color:var(--text-body);line-height:1.45}
.win-text strong{font-weight:700}

/* Setup guide */
.setup-guide{
  background:var(--surface);border-radius:var(--radius-xl);padding:20px 22px;
  border:1px solid var(--border);box-shadow:var(--card-shadow);animation:fadeInUp .5s var(--ease-out) .1s both;
}
.setup-guide-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px}
.setup-guide-title{font-size:14px;font-weight:700;color:var(--text-1);letter-spacing:-.01em}
.setup-guide-progress{font-size:12px;font-weight:600;color:var(--text-2)}
.setup-guide-done{font-size:12px;font-weight:700;color:rgb(90,159,59)}
.setup-collapsed{display:none}
.setup-collapsed.open{display:block}
.setup-show-more{background:none;border:none;font-family:var(--font-body);font-size:12px;font-weight:600;color:var(--freeze-text);cursor:pointer;padding:12px 0 2px;text-align:left;width:100%;transition:opacity 140ms ease}
.setup-show-more:hover{opacity:.7}
.setup-step{display:flex;align-items:flex-start;gap:12px;padding:12px 10px;border-bottom:1px solid var(--border);margin:0 -8px;border-radius:var(--radius-sm);cursor:default;transition:background 140ms ease}
.setup-step:last-child{border-bottom:none;padding-bottom:10px}
.setup-step.actionable{cursor:pointer}
.setup-step.actionable:hover{background:rgba(6,11,43,.04)}
.setup-step-check{
  width:20px;height:20px;border-radius:5px;border:2px solid var(--border-strong);
  display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px;
}
.setup-step.done .setup-step-check{background:var(--void);border-color:var(--void)}
.setup-step.done .setup-step-check svg{display:block}
.setup-step-check svg{width:10px;height:10px;color:#fff;display:none}
.setup-step.highlighted{box-shadow:var(--card-shadow)}
.setup-step.highlighted .setup-step-check{border-color:var(--freeze);background:var(--freeze-soft)}
.setup-step-info{flex:1}
.setup-step-title{font-size:14px;font-weight:500;color:var(--text-body)}
.setup-step.done .setup-step-title{color:var(--text-2)}
.setup-step-desc{font-size:13px;color:var(--text-2);font-weight:400;margin-top:2px;line-height:1.5;letter-spacing:-.005em}
.setup-step-action{
  font-size:12px;font-weight:700;color:var(--freeze-text);cursor:pointer;white-space:nowrap;
  margin-top:4px;display:block;transition:opacity 150ms ease;text-decoration:none;
}
.setup-step-action:hover{opacity:.7}

/* Document artifact — markdown-style preview */
/* Artifact fills pane height when rendered as primary view */
.app.settled .main-pane:has(.artifact-wrap){overflow:hidden;display:flex;flex-direction:column}
.artifact-wrap{flex:1;display:flex;flex-direction:column;padding:28px 32px;min-height:0;position:relative}
.artifact-wrap .artifact-doc{flex:1;display:flex;flex-direction:column;min-height:0;max-width:760px}
.artifact-wrap .artifact-doc-content{flex:1;overflow-y:auto;max-height:none}

.artifact-doc{
  background:var(--surface);border-radius:var(--radius-xl);
  box-shadow:var(--shadow-lifted);overflow:hidden;
  animation:fadeInUp .5s var(--ease-out) both;max-width:800px;
}
.artifact-doc-topbar{
  padding:12px 24px;border-bottom:1px solid var(--border);
  display:flex;align-items:center;gap:10px;background:var(--bg);
}
.artifact-doc-icon{
  width:30px;height:30px;border-radius:8px;background:var(--void);
  display:flex;align-items:center;justify-content:center;flex-shrink:0;
}
.artifact-doc-icon svg{width:14px;height:14px;color:#fff}
.artifact-doc-name{flex:1;font-size:13px;font-weight:600;color:var(--text-1)}
.artifact-doc-badge{
  font-size:11px;font-weight:600;color:rgb(52,120,48);
  background:rgba(134,197,100,.15);border:1px solid rgba(134,197,100,.35);
  border-radius:var(--radius-pill);padding:3px 11px;white-space:nowrap;
}
.artifact-doc-content{padding:32px 36px;overflow-y:auto;max-height:calc(100vh - 280px)}
.artifact-scroll-arrow{
  position:absolute;bottom:44px;left:50%;transform:translateX(-50%);
  width:32px;height:32px;border-radius:50%;
  background:var(--void);color:#fff;
  display:flex;align-items:center;justify-content:center;
  font-size:15px;line-height:1;
  pointer-events:none;z-index:20;
  opacity:1;transition:opacity 0.35s ease;
  animation:scrollBounce 1.6s ease-in-out infinite;
}
.artifact-scroll-arrow.hidden{opacity:0;pointer-events:none}
@keyframes scrollBounce{0%,100%{transform:translateX(-50%) translateY(0)}50%{transform:translateX(-50%) translateY(5px)}}
.artifact-doc-title{
  font-size:26px;font-weight:800;color:var(--text-1);letter-spacing:-.03em;
  line-height:1.2;margin-bottom:4px;font-family:var(--font);
}
.artifact-doc-byline{
  font-size:12.5px;color:var(--text-2);margin-bottom:28px;
  padding-bottom:20px;border-bottom:2px solid var(--border);
}
.artifact-section{margin-bottom:28px}
.artifact-section:last-child{margin-bottom:0}
.artifact-h2{
  font-size:10px;font-weight:700;letter-spacing:.09em;text-transform:uppercase;
  color:var(--text-2);margin-bottom:12px;padding-bottom:7px;
  border-bottom:1px solid var(--border);
}
.artifact-note{
  font-size:14px;color:var(--text-body);line-height:1.65;
  background:var(--bg);border-radius:var(--radius-sm);
  padding:14px 16px;margin-bottom:4px;border-left:3px solid var(--border-strong);
}
.artifact-checklist{list-style:none;display:flex;flex-direction:column;gap:8px;padding:0}
.artifact-check-item{
  display:flex;align-items:flex-start;gap:10px;
  font-size:13.5px;color:var(--text-body);line-height:1.55;
}
.artifact-check-box{
  width:17px;height:17px;border-radius:4px;border:1.5px solid var(--border-strong);
  flex-shrink:0;margin-top:2px;
}
.artifact-bullets{list-style:none;display:flex;flex-direction:column;gap:8px;padding:0}
.artifact-bullet-item{
  display:flex;align-items:flex-start;gap:10px;
  font-size:13.5px;color:var(--text-body);line-height:1.55;
}
.artifact-bullet-dash{color:var(--text-2);flex-shrink:0;font-weight:600;line-height:1.55}
.artifact-script-block{
  background:var(--bg);border-left:3px solid rgba(156,156,227,.5);
  border-radius:0 var(--radius-sm) var(--radius-sm) 0;
  padding:11px 16px;margin-bottom:8px;
}
.artifact-script-label{
  font-size:10px;font-weight:700;letter-spacing:.07em;text-transform:uppercase;
  color:var(--text-2);margin-bottom:5px;display:block;
}
.artifact-script-text{
  font-size:14px;color:var(--text-body);line-height:1.65;font-style:italic;margin:0;
}
.artifact-caution{
  display:flex;align-items:flex-start;gap:10px;
  font-size:13.5px;color:var(--text-body);line-height:1.5;
  padding:6px 0;
}
.artifact-caution-x{color:rgb(180,60,60);flex-shrink:0;font-weight:700;font-size:14px}

/* Tour module preview */
.tour-module{padding:18px 32px 28px;animation:fadeInUp .4s var(--ease-out) both}
.tour-module-label{font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--text-2);margin-bottom:8px}
.tour-module-title{font-size:28px;font-weight:800;color:var(--text-1);letter-spacing:-.03em;line-height:1.15;margin-bottom:10px;font-family:var(--font)}
.tour-module-desc{font-size:14px;color:var(--text-body);line-height:1.6;max-width:480px;opacity:.8}
.tour-module-visual{
  margin-top:24px;height:180px;border-radius:var(--radius-lg);
  background:linear-gradient(135deg,var(--void-04),var(--freeze-soft));
  border:1px solid var(--border);
  display:flex;align-items:center;justify-content:center;
}
.tour-module-visual svg{width:48px;height:48px;color:var(--freeze);opacity:.4}

/* Tour visual screens */
.tv-wrap{display:flex;flex-direction:column;gap:0;padding-top:4px}
.tv-eyebrow{font-size:11px;font-weight:600;letter-spacing:.07em;text-transform:uppercase;color:var(--text-2);margin-bottom:4px}
.tv-section-title{font-size:20px;font-weight:800;color:var(--text-1);letter-spacing:-.025em;line-height:1.2;font-family:var(--font)}
.tv-label{font-size:11px;font-weight:700;letter-spacing:.07em;text-transform:uppercase;color:var(--text-2)}
.tv-card-sub{font-size:12px;color:var(--text-2);line-height:1.5;letter-spacing:-.005em;margin-top:2px}

/* NBA next best action */
.tv-nba{display:flex;align-items:center;gap:14px;background:var(--void);border-radius:var(--radius-lg);padding:16px 18px;margin-bottom:12px}
.tv-nba-left{flex:1}
.tv-nba-title{font-size:14px;font-weight:700;color:#fff;margin:1px 0 2px}
.tv-nba-sub{font-size:12.5px;color:rgba(255,255,255,.6);font-weight:400;line-height:1.5}
.tv-nba-btn{background:rgba(255,255,255,.12);border:none;border-radius:var(--radius-pill);padding:8px 16px;font-size:12.5px;font-weight:700;color:#fff;cursor:pointer;white-space:nowrap;font-family:var(--font-body)}
.tv-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:10px}
.tv-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:12px 14px}
.tv-card-title{font-size:13.5px;font-weight:700;color:var(--text-1);margin:3px 0 6px}
.tv-prog-track{height:5px;border-radius:3px;background:var(--void-08);overflow:hidden}
.tv-prog-fill{height:100%;border-radius:2px;background:linear-gradient(90deg,var(--freeze),rgba(156,156,227,.5))}
.tv-setup-row{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:12px 14px}
.tv-chip-todo{display:inline-flex;align-items:center;gap:5px;font-size:11.5px;font-weight:500;color:var(--text-2);background:var(--void-04);border-radius:var(--radius-pill);padding:4px 10px}
.tv-chip-todo::before{content:'';width:5px;height:5px;border-radius:50%;border:1.5px solid var(--text-4);flex-shrink:0}

/* Goals screen */
.tv-active-goal{background:var(--surface);border:1.5px solid var(--border-strong);border-radius:var(--radius-lg);padding:16px 18px;margin-bottom:4px}
.tv-ag-title{font-size:18px;font-weight:800;color:var(--text-1);letter-spacing:-.025em;margin:4px 0;font-family:var(--font)}
.tv-milestone{display:flex;align-items:center;gap:8px;font-size:12.5px;font-weight:500;color:var(--text-body);padding:3px 0}
.tv-ms-dim{color:var(--text-3)}
.tv-ms-dot{width:7px;height:7px;border-radius:50%;border:1.5px solid var(--text-4);flex-shrink:0}
.tv-ms-dot-active{background:var(--freeze);border-color:var(--freeze)}
.tv-other-goal{display:flex;align-items:center;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:10px 14px;gap:10px}
.tv-og-name{font-size:13px;font-weight:500;color:var(--text-body)}
.tv-og-cta{font-size:12px;font-weight:600;color:var(--freeze);white-space:nowrap}

/* Home tour — KPI HUD */
.tv-kpi-hud{display:flex;border:1px solid var(--border);border-radius:var(--radius-lg);overflow:hidden;background:var(--surface);margin-bottom:13px}
.tv-kpi-hud-cell{flex:1;padding:16px 18px;border-right:1px solid var(--border)}
.tv-kpi-hud-cell:last-child{border-right:none}
.tv-kpi-hud-label{font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.07em;color:var(--text-2);margin-bottom:6px}
.tv-kpi-hud-val{font-size:17px;font-weight:700;color:var(--text-1);letter-spacing:-.03em;line-height:1.15;font-family:var(--font)}
.tv-trend-up{font-size:11.5px;font-weight:600;color:rgb(52,120,48)}
.tv-trend-down{font-size:11.5px;font-weight:600;color:rgb(185,50,50)}
/* Home tour — enhanced feature cards */
.tv-home-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-lg);padding:16px;display:flex;flex-direction:column;min-height:160px}
.tv-home-card-eyebrow{font-size:9.5px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--text-2);margin-bottom:6px}
.tv-home-card-title{font-size:14px;font-weight:800;color:var(--text-1);letter-spacing:-.015em;margin-bottom:4px;font-family:var(--font)}
.tv-home-card-sub{font-size:13px;color:var(--text-2);font-weight:400;margin-bottom:auto;line-height:1.5}
.tv-home-card .tv-home-card-btn{margin-top:14px;width:100%;padding:10px 14px;border-radius:var(--radius-sm);font-size:12.5px;font-weight:700;cursor:pointer;font-family:var(--font-body);text-align:left;border:none}
.tv-insight-hint{background:var(--freeze-soft);border-radius:var(--radius-sm);padding:7px 9px;font-size:10.5px;color:var(--freeze-text);font-weight:500;margin-top:auto;line-height:1.4;display:flex;align-items:flex-start;gap:5px}

/* Training screen — video card grid */
.tv-course-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-top:6px}
.tv-course-hero-wrap{grid-column:1/-1;border-radius:var(--radius-lg);overflow:hidden;position:relative;height:140px;cursor:pointer}
.tv-course-card-wrap{border-radius:var(--radius-lg);overflow:hidden;position:relative;height:120px;cursor:pointer}
.tv-course-overlay{position:absolute;inset:0;display:flex;flex-direction:column;justify-content:flex-end;padding:14px 18px}
