function peekModule(id) {
  clearTimeouts();
  var mod = null;
  for (var i = 0; i < TOUR_MODULES.length; i++) {
    if (TOUR_MODULES[i].id === id) { mod = TOUR_MODULES[i]; break; }
  }
  if (!mod) return;
  appEl().classList.add('settled');
  setNavActive(id);
  mainPane().innerHTML =
    '<div class="tour-module">' +
      (mod.id === 'home' ? '' : '<h2 class="tour-module-title">' + esc(mod.label) + '</h2>') +
      (TOUR_SCREENS[id] || '') +
    '</div>';
  clearMsgs();
  push(botMsg(mod.copy), 300);
  var bT = setTimeout(function() {
    push(
      '<button class="btn btn-secondary" style="margin-top:12px" onclick="navigateTo(\'home-settled\')">\u2190 Back to Home</button>',
      0
    );
  }, 1200);
  msgTimeouts.push(bT);
}

/* ── TOUR ────────────────────────────────────────────────────── */
function showTour() {
  tourIdx = 0;
  sageHide();
  tourCompleted = true;
  /* Clear stale content so every entry path starts clean */
  var mp = mainPane();
  mp.style.transition = 'opacity .18s ease';
  mp.style.opacity = '0';
  setTimeout(function() { mp.innerHTML = ''; mp.style.opacity = '1'; }, 200);
  appEl().classList.add('settled');
  appEl().classList.add('tour-mode');
  showCompanion();
  setThreadTitle('Product tour');
  clearMsgs();
  push(botMsg('I\u2019ll show you how each feature can help improve your business.'), 300);
  var t1 = setTimeout(function() {
    /* Companion spinner */
    var genEl = document.createElement('div');
    genEl.className = 'msg visible';
    genEl.innerHTML = '<div class="generating"><div class="gen-spinner"></div><span class="gen-text">Personalizing your tour\u2026</span></div>';
    cMsgs().appendChild(genEl);
    cMsgsScroll().scrollTop = cMsgsScroll().scrollHeight;

    /* Pulse the app bg while personalizing */
    appEl().classList.add('tour-pulsing');

    /* Kick off stop 1 */
    var t2 = setTimeout(function() { renderTourStop(); }, 2650);
    msgTimeouts.push(t2);
  }, 1200);
  msgTimeouts.push(t1);
}


function convTourToggleDropdown() {
  var dd = document.getElementById("convTourDropdown");
  var chev = document.getElementById("convTourChev");
  if (!dd) return;
  var open = dd.style.display !== "none";
  dd.style.display = open ? "none" : "block";
  if (chev) chev.style.transform = open ? "" : "rotate(180deg)";
  if (!open) setTimeout(function() {
    document.addEventListener("click", function closer(e) {
      if (!e.target.closest("#convTourModeBtn") && !dd.contains(e.target)) {
        dd.style.display = "none"; if (chev) chev.style.transform = "";
        document.removeEventListener("click", closer);
      }
    });
  }, 10);
}
function renderTourStop() {
  clearTimeouts();
  setProgress(Math.round((tourIdx + 1) / TOUR_MODULES.length * 100));
  var mod = TOUR_MODULES[tourIdx];
  setNavActive(mod.id);

  appEl().classList.remove('tour-pulsing');
  mainPane().scrollTop = 0;
  mainPane().innerHTML =
    '<div class="tour-module">' +
      (mod.id === 'home' ? '' : '<h2 class="tour-module-title">' + esc(mod.label) + '</h2>') +
      (TOUR_SCREENS[mod.id] || '') +
    '</div>';
  updateClocks();

  clearMsgs();
  push(botMsg(mod.copy), 300);

  var isLast = tourIdx === TOUR_MODULES.length - 1;
  var t = setTimeout(function() {
    if (!isLast) {
      push('<button class="btn btn-primary tour-btn" onclick="tourNext()">Continue \u2192</button>', 0);
    } else {
      push('<button class="btn btn-primary tour-btn" onclick="navigateTo(\'tour-complete\')">I\u2019m ready to dive in \u2192</button>', 0);
    }
  }, 600);
  msgTimeouts.push(t);
  updateNavArrows();

}

function tourNext() {
  if (tourIdx < TOUR_MODULES.length - 1) { tourIdx++; renderTourStop(); }
}

function jumpToTourEvents() {
  clearTimeouts();
  for (var i = 0; i < TOUR_MODULES.length; i++) {
    if (TOUR_MODULES[i].id === 'events') { tourIdx = i; break; }
  }
  currentScreen = 'tour';
  appEl().classList.add('settled');
  appEl().classList.add('tour-mode');
  showCompanion();
  setThreadTitle('Product tour');
  renderTourStop();
}


/* ── SAGE MODES ─────────────────────── */
var sageMode = "working";
var sageModeMessages = { thinking: "What’s on your mind?", working: "What can I take off your plate?", listening: "I’m here. What’s going on?" };

function sageToggleDropdown() {
  var dd = document.getElementById("sageModeDropdown"), chev = document.getElementById("sageModeChevron");
  if (!dd) return;
  var open = dd.style.display !== "none";
  dd.style.display = open ? "none" : "block";
  if (chev) chev.style.transform = open ? "" : "rotate(180deg)";
  var opts = dd.querySelectorAll(".sage-mode-option");
  for (var i = 0; i < opts.length; i++) {
    var isActive = opts[i].dataset.mode === sageMode;
    opts[i].classList.toggle("active", isActive);
    opts[i].style.background = isActive ? "var(--void-08)" : "none";
    opts[i].style.color = isActive ? "var(--text-1)" : "var(--text-2)";
    opts[i].style.fontWeight = isActive ? "600" : "500";
  }
  if (!open) setTimeout(function() {
    document.addEventListener("click", function closer(e) {
      if (!e.target.closest("#sageModeBtn")) {
        dd.style.display = "none"; if (chev) chev.style.transform = "";
        document.removeEventListener("click", closer);
      }
    });
  }, 10);
}

function sageSelectMode(mode) {
  sageMode = mode;
  var label = document.getElementById("sageModeLabel");
  if (label) label.textContent = mode.charAt(0).toUpperCase() + mode.slice(1);
  var dd = document.getElementById("sageModeDropdown"), chev = document.getElementById("sageModeChevron");
  if (dd) dd.style.display = "none"; if (chev) chev.style.transform = "";
  sageSwapGreeting(sageModeMessages[mode]);
}

function sageSwapGreeting(text) {
  var b = document.querySelector("#cMsgsInner .msg .msg-bubble.bot");
  if (b) { b.style.transition = "opacity 150ms ease"; b.style.opacity = "0";
    setTimeout(function() { b.textContent = text; b.style.opacity = "1"; }, 150); }
}

function sageShowHome() {
  sageMode = "working";
  var row = document.getElementById("sageModeRow");
  var label = document.getElementById("sageModeLabel");
  if (row) row.style.display = "flex";
  if (label) label.textContent = "Working";
}

function sageHide() {
  var row = document.getElementById("sageModeRow");
  if (row) row.style.display = "none";
}


