function ob_askQuestion(btn) {
  var spans = btn.querySelectorAll('span');
  var questionText = spans.length > 1 ? spans[1].textContent : btn.textContent;
  btn.classList.add('used');
  setTimeout(function() { btn.style.display = 'none'; }, 460);

  var messages = document.getElementById('chatMessages');

  var userTemplate = document.getElementById('userMsgTemplate');
  var userClone = userTemplate.content.cloneNode(true);
  userClone.querySelector('.user-msg-bubble').textContent = questionText;
  messages.appendChild(userClone);

  var typingTemplate = document.getElementById('typingTemplate');
  var typingClone = typingTemplate.content.cloneNode(true);
  var typingEl = typingClone.firstElementChild || typingClone.children[0];
  messages.appendChild(typingClone);
  orbAlive(true);
  /* Only scroll the chat — don't scroll the outer step yet (reduces bounce) */
  messages.scrollTop = messages.scrollHeight;

  /* Look up brand + biz-type specific answer, fall back to _default */
  var responseText;
  var brandAnswers = aiResponseMap[currentBrand];
  if (brandAnswers) {
    var bizPill = document.querySelector('#bizTypeGroup .radio-pill.selected');
    var bizType = bizPill ? bizPill.textContent.trim() : '';
    responseText = (brandAnswers[bizType] && brandAnswers[bizType][questionText]) || brandAnswers[questionText] || (brandAnswers['Suite'] && brandAnswers['Suite'][questionText]);
  }
  if (!responseText) responseText = aiResponseMap._default[questionText] || "That\u2019s a great question. Let me dig into the specifics for your business.";

  setTimeout(function() {
    orbAlive(false);
    if (typingEl && typingEl.parentNode) {
      typingEl.parentNode.removeChild(typingEl);
    }
    var aiTemplate = document.getElementById('aiMsgTemplate');
    var aiClone = aiTemplate.content.cloneNode(true);
    aiClone.querySelector('.chat-msg-bubble').textContent = responseText;
    messages.appendChild(aiClone);
    ob_scrollCompanionIntoView(messages);
  }, 1400);
}


