      ob_updatePlanTotal(); /* sync summary bar with current plan selection */
      setTimeout(function() { var f = document.getElementById('cardName'); if (f) f.focus(); }, 500);
    }

    setTimeout(function() { next.classList.remove('entering'); }, 600);
  }, 220);
}

