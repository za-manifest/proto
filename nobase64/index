/* Populate Sage starter questions based on selected goals — safe DOM only */
function populateStarterQuestions() {
  var container = document.getElementById('starterQuestions');
  while (container.firstChild) {
    container.removeChild(container.firstChild);
  }

  var questions = [];
  var usedTexts = {};
  ob_selectedGoals.forEach(function(card) {
    var goalName = card.querySelector('.card-title').textContent;
    if (goalQuestionMap[goalName]) {
      questions.push(goalQuestionMap[goalName]);
      usedTexts[goalQuestionMap[goalName].text] = true;
    }
  });

  /* Fall-back: always show exactly 3 prompts — backfill from default stack ranking (defaultQuestions array) even if user selects only 1 or 2 goals */
  if (questions.length < 3) {
    for (var d = 0; d < defaultQuestions.length && questions.length < 3; d++) {
      if (!usedTexts[defaultQuestions[d].text]) {
        questions.push(defaultQuestions[d]);
        usedTexts[defaultQuestions[d].text] = true;
      }
    }
  }

  for (var i = 0; i < Math.min(questions.length, 3); i++) {
    var btn = document.createElement('button');
    btn.className = 'starter-q';
    btn.setAttribute('data-q', String(i));

    var emojiSpan = document.createElement('span');
    emojiSpan.className = 'prompt-emoji';
    emojiSpan.textContent = questions[i].emoji;
    btn.appendChild(emojiSpan);

    var textSpan = document.createElement('span');
    textSpan.textContent = questions[i].text;
    btn.appendChild(textSpan);

    btn.onclick = function() { ob_askQuestion(this); };
    container.appendChild(btn);
