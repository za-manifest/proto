/* Phone validation — basic syntax check for mobile numbers */
function ob_formatPhone(input) {
  var digits = input.value.replace(/\D/g, '');
  if (digits.length === 0) { input.value = ''; return; }
  if (digits.length <= 3) { input.value = '(' + digits; }
  else if (digits.length <= 6) { input.value = '(' + digits.slice(0, 3) + ') ' + digits.slice(3); }
  else { input.value = '(' + digits.slice(0, 3) + ') ' + digits.slice(3, 6) + '-' + digits.slice(6, 10); }
}
function formatPhone(input) { ob_formatPhone(input); } /* alias */

function ob_validatePhone(input) {
  var error = document.getElementById('phoneError');
  var digits = input.value.replace(/\D/g, '');
  if (digits.length === 0) { input.style.borderColor = ''; if (error) error.style.display = 'none'; return; }
  if (digits.length < 10 || digits.length > 11) {
    input.style.borderColor = '#C53030';
    if (error) error.style.display = '';
  } else {
    input.style.borderColor = '';
    if (error) error.style.display = 'none';
  }
}
function validatePhone(input) { ob_validatePhone(input); } /* alias */

/* Website validation — accept real URLs only */
function ob_validateWebsite(input) {
  var error = document.getElementById('websiteError');
  var val = input.value.trim();
  if (!val) { input.style.borderColor = ''; if (error) error.style.display = 'none'; return; }
  if (!/^https?:\/\//i.test(val)) { val = 'https://' + val; input.value = val; }
  var pattern = /^https?:\/\/[a-zA-Z0-9][-a-zA-Z0-9.]*\.[a-zA-Z]{2,}(\/.*)?$/;
  if (!pattern.test(val)) {
    input.style.borderColor = '#C53030';
    if (error) error.style.display = '';
  } else {
    input.style.borderColor = '';
    if (error) error.style.display = 'none';
  }
}
function validateWebsite(input) { ob_validateWebsite(input); } /* alias */

/* Navigation */
function ob_nextStep() {
  if (ob_currentStep >= ob_totalSteps) return;

  /* Store first name when leaving step 4 (Tell us about your business) */
  if (ob_currentStep === 4) {
    var fnEl = document.getElementById('firstName');
    if (fnEl && fnEl.value.trim()) ob_storedFirstName = fnEl.value.trim();
  }

  /* Before leaving step 6 (learning plans) into demo steps, populate AI companion questions and update dashboard */
  if (ob_currentStep === 6) {
    populateStarterQuestions();
    updateDashboardTitle();
  }

  /* Skip step 12 (confirmation removed — payment goes straight to auth) */
  var nextStep = ob_currentStep + 1;
  if (nextStep === 12) nextStep = 13;

  ob_transitionTo(nextStep);
}

function ob_prevStep() {
  if (ob_currentStep <= 3) return;
  if (ob_currentStep >= 13) return; /* no going back once in auth flow */
  ob_transitionTo(ob_currentStep - 1);
}

function ob_transitionTo(step) {
  var current = document.querySelector('[data-step="' + ob_currentStep + '"]');
  var next = document.querySelector('[data-step="' + step + '"]');
  if (!current || !next) return;

  current.classList.add('exiting');

  setTimeout(function() {
    current.classList.remove('active', 'exiting', 'entering');
    current.style.display = 'none';
    ob_currentStep = step;
    ob_updateDebugNav();
    var dnc = document.getElementById('debugNavContainer');
    if (dnc) dnc.style.display = (step === 14) ? 'none' : 'flex';

    var _stepOrder = [3,4,5,6,7,8,9,10,11,13,14];
    var _idx = _stepOrder.indexOf(step);
    var progress = _idx < 0 ? 0 : Math.round((_idx / (_stepOrder.length - 1)) * 100);
    document.getElementById('progressFill').style.width = progress + '%';

    var backBtn = document.getElementById('backBtn');
    if (step > 3 && step < 13) { backBtn.classList.add('visible'); }
    else { backBtn.classList.remove('visible'); }

    next.style.display = 'flex';
    next.classList.add('active', 'entering');

    var items = next.querySelectorAll('.si');
    for (var i = 0; i < items.length; i++) {
      items[i].style.animationDelay = (i * 70 + 80) + 'ms';
