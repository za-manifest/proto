}

function _initArtifactScroll() {
  var wrap = mainPane().querySelector('.artifact-wrap');
  var content = mainPane().querySelector('.artifact-doc-content');
  if (wrap && content) {
    var arrow = document.createElement('div');
    arrow.className = 'artifact-scroll-arrow';
    arrow.innerHTML = '\u2193';
    wrap.appendChild(arrow);
    var checkScroll = function() {
      var atBottom = content.scrollTop + content.clientHeight >= content.scrollHeight - 12;
      arrow.classList.toggle('hidden', atBottom);
    };
    content.addEventListener('scroll', checkScroll);
    setTimeout(checkScroll, 200);
  }
}


