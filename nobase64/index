    Object.keys(overrides).forEach(function(idx) {
      var i = parseInt(idx, 10);
      tasks[i] = Object.assign({}, tasks[i], overrides[i]);
      /* preserve done state from base */
      if (base[i].done) tasks[i].done = true;
    });
  }
  GOAL_TASKS[key] = tasks;
  return tasks;
}
