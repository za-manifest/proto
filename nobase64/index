function markSetupStepDone(title, newDesc) {
  var steps = document.querySelectorAll('.setup-collapsed .setup-step');
  for (var i = 0; i < steps.length; i++) {
    var t = steps[i].querySelector('.setup-step-title');
    if (t && t.textContent === title) {
      steps[i].classList.add('done');
      steps[i].classList.remove('actionable');
      steps[i].removeAttribute('onclick');
      if (newDesc) {
        var d = steps[i].querySelector('.setup-step-desc');
        if (d) d.textContent = newDesc;
      }
      updateLaunchpadCount();
      break;
    }
  }
}

function updateLaunchpadCount() {
  var all = document.querySelectorAll('.setup-guide .setup-step');
  var n = 0;
  for (var i = 0; i < all.length; i++) { if (all[i].classList.contains('done')) n++; }
  var el = document.querySelector('.setup-guide-done');
  if (n > 0) {
    if (el) { el.textContent = n + ' done \u2713'; }
    else {
      var hdr = document.querySelector('.setup-guide-header');
      if (hdr) {
        var s = document.createElement('span');
        s.className = 'setup-guide-done';
        s.textContent = n + ' done \u2713';
        hdr.appendChild(s);
      }
    }
  }
}

