/* Verification code input handling — legacy no-op; real init is ob_initCodeInputs13() */
function initCodeInputs() {
  /* inputs are now handled per-step by ob_initCodeInputs13() */
  var inputs = document.querySelectorAll('#ob_codeInputs13 .code-input');

  inputs.forEach(function(input, idx) {
    input.addEventListener('input', function(e) {
      var val = this.value.replace(/[^0-9]/g, '');
      this.value = val ? val[0] : '';

      if (val) {
        this.classList.add('filled');
        if (idx < 5) inputs[idx + 1].focus();
      } else {
        this.classList.remove('filled');
      }

      checkCodeComplete();
    });

    input.addEventListener('keydown', function(e) {
      if (e.key === 'Backspace') {
        if (!this.value && idx > 0) {
          inputs[idx - 1].focus();
          inputs[idx - 1].value = '';
          inputs[idx - 1].classList.remove('filled');
        } else {
          this.value = '';
          this.classList.remove('filled');
        }
        checkCodeComplete();
      }
      if (e.key === 'ArrowLeft' && idx > 0) { e.preventDefault(); inputs[idx - 1].focus(); }
      if (e.key === 'ArrowRight' && idx < 5) { e.preventDefault(); inputs[idx + 1].focus(); }
    });

    input.addEventListener('focus', function() {
      this.select();
      this.classList.remove('error');
    });

    input.addEventListener('paste', function(e) {
      e.preventDefault();
      var paste = (e.clipboardData || window.clipboardData).getData('text').replace(/[^0-9]/g, '');
      if (!paste) return;

      for (var i = 0; i < Math.min(paste.length, 6); i++) {
        inputs[i].value = paste[i];
        inputs[i].classList.add('filled');
      }
      var focusIdx = Math.min(paste.length, 5);
      inputs[focusIdx].focus();

      checkCodeComplete();
    });
  });
}

