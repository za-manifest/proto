    var phone = phoneInput ? phoneInput.value.trim() : '';
    if (phone && phone.length >= 10) {
      var digits = phone.replace(/\D/g,'');
      var masked = '(•••) •••-' + digits.slice(-4);
      verifySubtext.textContent = 'We texted a 6-digit code to ' + masked + '.';
    } else {
      verifySubtext.textContent = 'We texted a 6-digit code to your number.';
    }
  }
  // Init code inputs for step 13
  ob_initCodeInputs13();
  // Start resend timer
  ob_startResendTimer();
}

function ob_initCodeInputs13() {
  var inputs = document.querySelectorAll('#ob_codeInputs13 .code-input');
  inputs.forEach(function(input, idx) {
    input.value = '';
    input.classList.remove('filled', 'error', 'success');
    input.addEventListener('input', function(e) {
      var val = this.value.replace(/[^0-9]/g, '');
      this.value = val ? val[0] : '';
      if (val) {
        this.classList.add('filled');
        if (idx < 5) inputs[idx + 1].focus();
      } else {
        this.classList.remove('filled');
      }
      ob_checkCode13();
    });
    input.addEventListener('keydown', function(e) {
      if (e.key === 'Backspace') {
        if (!this.value && idx > 0) { inputs[idx-1].focus(); inputs[idx-1].value=''; inputs[idx-1].classList.remove('filled'); }
        else { this.value=''; this.classList.remove('filled'); }
        ob_checkCode13();
      }
      if (e.key === 'ArrowLeft' && idx > 0) { e.preventDefault(); inputs[idx-1].focus(); }
      if (e.key === 'ArrowRight' && idx < 5) { e.preventDefault(); inputs[idx+1].focus(); }
    });
    input.addEventListener('focus', function() { this.select(); this.classList.remove('error'); });
    input.addEventListener('paste', function(e) {
      e.preventDefault();
      var paste = (e.clipboardData||window.clipboardData).getData('text').replace(/[^0-9]/g,'');
      if (!paste) return;
      for (var i = 0; i < Math.min(paste.length,6); i++) { inputs[i].value=paste[i]; inputs[i].classList.add('filled'); }
      inputs[Math.min(paste.length-1,5)].focus();
      ob_checkCode13();
    });
  });
}

function ob_checkCode13() {
  var inputs = document.querySelectorAll('#ob_codeInputs13 .code-input');
  var code = '';
  inputs.forEach(function(i) { code += i.value; });
  if (code.length === 6) {
    inputs.forEach(function(i) { i.disabled = true; });
    setTimeout(function() {
      var container = document.getElementById('ob_codeInputs13');
      if (container) container.classList.add('success');
      inputs.forEach(function(i) { i.classList.add('success'); i.classList.remove('filled'); });
      var vs = document.getElementById('ob_verifyStatus');
      if (vs) vs.classList.add('visible');
      setTimeout(function() {
        inputs.forEach(function(i) { i.disabled = false; });
        ob_transitionTo(14);
      }, 900);
    }, 600);
  }
}

